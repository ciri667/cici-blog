# Environment (development/production)
# 在生产环境必须设置为 production
ENVIRONMENT=development

# Database - PostgreSQL connection URL
# 生产环境必须设置！
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cici_blog

# JWT Secret Key - 用于签名 JWT 令牌
# 生产环境必须设置且至少 32 个字符！
# 可使用: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin whitelist (comma-separated)
ADMIN_EMAILS=your-email@example.com
ADMIN_GITHUB_USERNAMES=your-github-username

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_CDN_URL=

# AI / Agent
TAVILY_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
